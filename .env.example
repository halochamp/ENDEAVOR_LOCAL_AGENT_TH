# ENDEAVOR_LOCAL_AGENT_TH — Environment Variables
# Copy this file to .env and edit as needed (or export directly in your shell).
# All variables are optional — defaults shown here match out-of-the-box behaviour.
#
# Usage:
#   cp .env.example .env
#   source .env          # then run normally
#   # OR export individually before running

# ── LLM Backend ──────────────────────────────────────────────────────────────
# URL ของ mlx_lm.server (หรือ OpenAI-compatible server อื่น)
MLX_BASE_URL=http://localhost:8080/v1

# Model ที่ใช้ (ต้อง set คู่กับ MLX_BASE_URL ถ้าเปลี่ยน server)
# V2_MODEL=unsloth/Qwen3.6-35B-A3B-UD-MLX-4bit

# API key (mlx_lm.server ไม่เช็ค แต่ต้องไม่ว่าง)
# MLX_API_KEY=x

# ── Generation ────────────────────────────────────────────────────────────────
# V2_TEMPERATURE=0.1
# V2_MAX_TOKENS=8192
# V2_THINKING_BUDGET=2048      # จำกัด thinking tokens (0 = ปิด thinking)
# V2_REPETITION_PENALTY=1.05   # ป้องกัน thinking loop (0.0 = ปิด)
# V2_RECURSION_LIMIT=60        # max tool-call steps ต่อ 1 query

# ── Context Window ────────────────────────────────────────────────────────────
# V2_CONTEXT_MAX_CHARS=200000  # trim conversation เมื่อเกิน (≈50K tokens)

# ── Agent Server ──────────────────────────────────────────────────────────────
# port ของ WebSocket/REST server (สำหรับ web UI ที่ /ui)
# AGENT_SERVER_PORT=8765

# Token สำหรับ auth (ถ้าไม่ set → server สร้างให้อัตโนมัติและเซฟใน .agent_token)
# AGENT_SERVER_TOKEN=your-secret-token-here

# ปิด auth ทั้งหมด (dev เท่านั้น — ห้ามใช้ production)
# AGENT_AUTH_DISABLED=1

# ── Workspace & Logs ──────────────────────────────────────────────────────────
# V2_WORKSPACE=/path/to/workspace   # default: ./workspace (relative to project)
# V2_LOG_DIR=/path/to/logs          # default: ./logs
# V2_LOG_MAX_ENTRIES=5000

# ── Web Tool Limits ───────────────────────────────────────────────────────────
# V2_WEB_SEARCH_MAX_RESULTS=10
# V2_WEB_SEARCH_FETCH_TOP=4
# V2_WEB_SEARCH_FETCH_TIMEOUT=6
# V2_BROWSE_URL_MAX_CHARS=20000
# V2_BROWSER_USE_MAX_CHARS=8000
# V2_BATCH_BROWSE_MAX_WORKERS=2
# V2_BATCH_BROWSE_MAX_URLS=8
# V2_FETCH_SITEMAP_MAX_URLS=200
# V2_SCRAPE_TABLE_MAX_CHARS=10000
# V2_RECALL_WEB_MAX_CHARS=20000

# ── Web Cache ─────────────────────────────────────────────────────────────────
# V2_WEB_CACHE_MAX_ENTRIES=50
# V2_WEB_CACHE_MAX_BYTES=3000000
# V2_WEB_CACHE_PER_ENTRY_MAX=50000

# ── Summarization ─────────────────────────────────────────────────────────────
# V2_SUMMARY_MAX_CHARS=800
# V2_SUMMARY_MAX_TOKENS=1024
# V2_SUMMARY_SKIP_LLM_BELOW=1500   # ข้าม LLM summarize ถ้า raw ≤ ค่านี้

# ── File & Loop Tool Limits ───────────────────────────────────────────────────
# V2_READ_FILE_MAX_CHARS=10000
# V2_READ_FILE_MAX_BYTES=5242880    # 5 MB
# V2_TOOL_LOOP_DDG_MAX_RESULTS=8
# V2_TOOL_LOOP_READ_MAX_CHARS=6000
# V2_TOOL_LOOP_READ_SUMMARIZE_THRESHOLD=3000
# V2_TOOL_LOOP_BASH_MAX_CHARS=2000
# V2_TOOL_LOOP_BASH_TIMEOUT=30      # seconds
